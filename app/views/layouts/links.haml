%html{lang: "pt-br", "xml:lang" => "pt-br", xmlns: "http://www.w3.org/1999/xhtml"}
  %head
    %title Mostre!me Links
    %meta{content: "text/html;charset=UTF-8", "http-equiv" => "content-type"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    = stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    = stylesheet_link_tag "old"
    = favicon_link_tag 'favicon.ico'

  %body
    .container-fluid.p-3{style: "max-width: 700px; margin: auto;"}
      %h1
        = link_to "Mostre!me / links", "/links"
      .menu
        = yield :menu
        = link_to "Histórico", "/links/stats" unless request.fullpath == "/links/stats"

      - if flash[:notice]
        %p#status
          = flash[:notice]

      #meiuca
        = yield

      .rodape
        %span - linkando em
        = link_to "Mostre!me", "http://mostre.me"
        %span desde 2009 -
