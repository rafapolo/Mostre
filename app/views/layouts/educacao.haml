!!!
%html
  %head
    - if @title
      %title= "Mostre!me - #{@title}"
    - else
      %title Mostre!me
    %meta{charset: 'utf-8'}
    %meta{property: "og:description", content: "Mostre!me mapeia e integra os dados do Sistema de apoio às leis de incentivo à Cultura do Brasil, propondo modernas formas de interação e visualização dessas relevantes informações nacionais."}
    %meta{property: "og:image", content: "https://mostre.me" + asset_path('mapa.png')}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    = stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    = stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    = stylesheet_link_tag "application", media: "all"
    = stylesheet_link_tag "https://fonts.googleapis.com/css?family=Gudea"
    %script{src: "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"}
    = javascript_importmap_tags
    = favicon_link_tag 'favicon.ico'
    = yield :libs
    = csrf_meta_tags

  %body
    .container-fluid.p-0
      .d-flex{style: "min-height: 100vh;"}
        %button.d-md-none.btn.btn-dark.position-fixed.top-0.start-0.m-2{style: "z-index: 1045;", "data-bs-toggle" => "offcanvas", "data-bs-target" => "#sidebar", type: "button"}
          %i.bi.bi-list

        #sidebar.offcanvas.offcanvas-start.d-md-block{style: "width: 260px;", tabindex: "-1", "data-controller" => "nav"}
          .offcanvas-header.d-md-none
            %h5.offcanvas-title Menu
            %button.btn-close{"data-bs-dismiss" => "offcanvas", type: "button"}
          .offcanvas-body.p-3
            .logo.card.borda.mb-3.py-2{"data-controller" => "logo", "data-logo-path" => "/educacao"}
              .card-body.text-center.py-2
                Educação

            .list-group.list-group-flush.borda.mb-3
              %a.list-group-item.list-group-item-action{href: "/educacao"}
                %i.bi.bi-house-fill.me-2
                Início
                %i.bi.bi-chevron-right.float-end
              %a.list-group-item.list-group-item-action{href: "/educacao/mantenedoras"}
                %i.bi.bi-grid-fill.me-2
                Mantenedoras
                %i.bi.bi-chevron-right.float-end
              %a.list-group-item.list-group-item-action{href: "/educacao/instituicaos"}
                %i.bi.bi-briefcase-fill.me-2
                Instituições
                %i.bi.bi-chevron-right.float-end
              %a.list-group-item.list-group-item-action{href: "/educacao/cursos"}
                %i.bi.bi-hand-thumbs-up-fill.me-2
                Cursos
                %i.bi.bi-chevron-right.float-end

            - if content_for? :filtro
              #filtros.card.borda.mb-3
                .card-body.p-3
                  %i.bi.bi-search.me-1
                  %span Mostrar
                  %span.loading
                    = image_tag asset_path('load.gif')
                  %hr.small
                  = yield :filtro
              #filtro_estados
            - else
              - if request.fullpath != "/educacao"
                #ad{style: "height:400px; width:200px"}
                  = render partial: 'shared/adsense'

            = yield :dados



        #meio.flex-grow-1.p-3
          = yield

    #rodape
      %p.m-0 Mostre!me Educação | Copyfight 2015
