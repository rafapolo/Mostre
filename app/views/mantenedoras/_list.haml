- @mantenedoras ||= mantenedoras

%table.table.table-striped.table-bordered.table-condensed.borda
  %thead
    %tr
      %th{style: 'width: 420px'} Cod
      %th Natureza
      %th#situacao_at.reorder Representante
      %th#cursos.reorder Cursos
  %tbody
    - @mantenedoras.each do |mant|
      %tr
        %td= mant.cod_mec #todo: hightlight
        %td{style: "width: 250px"}= mant.natureza
        %td{style: "width: 400px"}= mant.representante
        %td= mant.instituicaos.count
        / %td= mant.segmento.nome
        / %td
        /   - if mant.situacao_at
        /     = mant.situacao_at.year
        /   - else
        /     %span.badge.bg-warning em avaliação

        / %td= reais mant.solicitado
        / - if mant.aprovado > 0
        /   %td= reais mant.aprovado
        / - else
        /   %td
        /     - if especial(mant)
        /       %span -
        /     - else
        /       %span.badge.bg-danger 0
        / %td
        /   - if mant.apoiado > 0
        /     = reais mant.apoiado
        /   - else
        /     - if mant.aprovado > 0
        /       %span.badge.bg-danger 0
        /     - else
        /       // sem aprovação e sem apoio
        /       %span -
        / %td
        /   - #todo: visualizar se soma de apoiadores não bate com apoiado.
        /   - if mant.apoiado > 0 && mant.apoiadores==0
        /     - if especial(mant)
        /       %span -
        /     - else
        /       %span.badge.bg-danger
        /         %i.icon-question-sign
        /   - else
        /     - if apoiadores=mant.apoiadores
        /       %span.badge.bg-info= apoiadores
        /     - else
        /       - if !apoiadores && !especial(mant) && mant.apoiado>0
        /         %span.badge.bg-danger 0
        /       - else
        /         %span -
        / %td
        /   - if at = mant.liberado_at
        /     %span.badge.bg-success= at
        /   - else
        /     - if (especial(mant))
        /       %span.badge.bg-warning
        /         %i.bi.bi-star-fill
        /     - else
        /       %span.badge.bg-danger
        /         %i.icon-ban-circle
