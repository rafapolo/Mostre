  - unless params[:estado_id]
    #estados
      .card.borda
        %i.bi.bi-globe
        Estados
        %hr.small
        - @estados.each do |e|
          - estado = e[0]
          - count = e[1]
          %p.selectable{type: 'estado', type_id: estado.id}
            %span.rotulo= estado.nome        
            - if count > 0
              %span.badge.bg-info= count
            - else
              %span.badge.bg-danger= count